{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXT_KEYCLOAK_CLIENT_SECRET",
        "NEXT_KEYCLOAK_CLIENT_ID",
        "NEXT_KEYCLOAK_ISSUER",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_API_BASE_URL_KEYCLOCK",
        "NEXT_PUBLIC_MASTER_URL",
        "NEXT_PUBLIC_WORKFLOW_URL",
        "NEXT_PUBLIC_REPORTS_URL",
        "NEXT_PUBLIC_DASHBOARD_URL",
        "NEXT_PUBLIC_LEAVE_URL",
        "NEXT_PUBLIC_MUSTER_URL",
        "NEXT_PUBLIC_WAGES_URL",
        "NEXT_PUBLIC_OTAPPLICATION_URL",
        "NEXT_PUBLIC_NEXTAUTH_URL",
        "NEXT_PUBLIC_BGM_URL",
        "NEXT_PUBLIC_AI_URL",
        "NEXT_PUBLIC_ENCRYPTION_KEY"
      ]
    },

    "dev:main": {
      "cache": false,
      "persistent": true,
      "dependsOn": []
    },
    "dev:subapps": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["dev:main"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["dev:main", "dev:subapps"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}